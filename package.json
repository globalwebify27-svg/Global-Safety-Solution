{
  "name": "global-safety-solution-erp",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "postinstall": "npm run generate --workspace=@repo/database",
    "render:build": "npm run db:push --workspace=@repo/database && npm run seed --workspace=backend && npm run seed:fix --workspace=backend && turbo run build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "latest"
  }
}
